# VNIBB Environment Configuration
# Copy to .env and fill in your values

# Application
APP_NAME=VNIBB
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development  # development, staging, production
TZ=Asia/Ho_Chi_Minh
INTRADAY_MARKET_TZ=Asia/Ho_Chi_Minh

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ADMIN_API_KEY=  # Optional; required for /api/v1/admin/errors/recent in production
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","https://vnibb-web.vercel.app"]
CORS_ORIGIN_REGEX=^https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$|^https://[a-z0-9-]+\\.vercel\\.app$
ALEMBIC_STRICT=0  # 1 = fail startup if migration fails, 0 = continue startup with warning

# Database (Supabase/Postgres primary + optional Appwrite fallback)
# For local development with Docker:
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vnibb

# For Supabase hosted (get from Supabase dashboard > Settings > Database):
# DATABASE_URL=postgresql+asyncpg://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Supabase API (optional, for direct Supabase client usage)
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here  # For JWT validation (get from Supabase Settings > API)

# Appwrite (optional legacy read fallback and manual projection target)
# Reuse the existing VNIBB Appwrite database only if you still need legacy reads or manual backfills.
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_API_KEY=your-appwrite-server-api-key
APPWRITE_DATABASE_ID=your-existing-vnibb-appwrite-database-id
APPWRITE_SYSTEM_TEMPLATES_COLLECTION_ID=system_dashboard_templates
APPWRITE_WRITE_ENABLED=false
# Future tenant collections (documented; not yet required in code):
# APPWRITE_TENANT_TEMPLATES_COLLECTION_ID=tenant_dashboard_templates
# APPWRITE_TENANT_MEMBERSHIPS_COLLECTION_ID=tenant_memberships
# APPWRITE_TENANT_AUDIT_COLLECTION_ID=tenant_audit_logs
# Optional aliases (used by MCP helper scripts):
# APPWRITE_NAME=your-appwrite-project-id
# APPWRITE_SECRET=your-appwrite-server-api-key

# VNIBB Read-only MCP companion
VNIBB_MCP_HOST=0.0.0.0
VNIBB_MCP_PORT=8001
VNIBB_MCP_TRANSPORT=stdio
VNIBB_MCP_URL=http://127.0.0.1:8001/mcp
VNIBB_MCP_TIMEOUT_SECONDS=20
# Recommended for remote/OCI deployments. Leave blank for local stdio use.
# VNIBB_MCP_SHARED_BEARER_TOKEN=replace-with-long-random-value

# Redis Cache
# For local development with Docker:
CACHE_BACKEND=auto  # auto, redis, memory, appwrite
DATA_BACKEND=hybrid  # postgres primary, Appwrite read fallback only when configured
ALLOW_ANONYMOUS_DASHBOARD_WRITES=true
APPWRITE_POPULATE_MAX_ROWS=1000  # Zeabur-safe default; raise only for off-peak catch-up runs
APPWRITE_POPULATE_FULL_MAX_ROWS=0  # 0 means no cap for full-refresh tables
APPWRITE_POPULATE_BATCH_SIZE=500
APPWRITE_POPULATE_CONCURRENCY=5
APPWRITE_POPULATE_FORCE_HTTP=1  # Use only when running a manual Appwrite projection/backfill
APPWRITE_POPULATE_RESUME=true
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300  # Default TTL in seconds (5 minutes)
PRICE_BACKFILL_START_DATE=2019-01-01

# VNStock Provider
VNSTOCK_API_KEY=your-api-key-here  # Golden Sponsor API key
VNSTOCK_RUNTIME_INSTALL=0  # Keep 0 in production; set 1 only for one-time runtime bootstrap
VNSTOCK_AUTO_BOOTSTRAP_ON_MISSING=1  # Auto-attempt runtime bootstrap if premium modules are missing
VNSTOCK_AUTO_BOOTSTRAP_INTERVAL_SECONDS=43200  # Cooldown between auto-bootstrap attempts (12h)
VNSTOCK_AUTO_BOOTSTRAP_MAX_FAILED_ATTEMPTS=5  # Pause auto-bootstrap after repeated failures
VNSTOCK_AUTO_BOOTSTRAP_LOCK_STALE_SECONDS=1800  # Recover stale lock after 30 minutes
VNSTOCK_PREMIUM_REQUIRED_MODULES=vnstock_data,vnstock_ta,vnstock_pipeline,vnstock_news,vnii  # Comma-separated import checks
VNSTOCK_SOURCE=KBS  # VNIBB default; supported sources are KBS, VCI, DNSE
VNSTOCK_TIMEOUT=30
VNSTOCK_RATE_LIMIT_RPS=8.333333  # Main budget: 500 req/min
VNSTOCK_REINFORCEMENT_RPS=0.833333  # Reserved budget: 50 req/min
VNSTOCK_CALLS_PER_MINUTE=100  # Practical steady-state budget under the daily cap
INTRADAY_SYMBOLS_PER_RUN=60  # Legacy/live symbol limiter used by trading flow syncs
SCHEDULER_LIVE_SYMBOLS_PER_RUN=60  # Priority-symbol slice during market hours
SCHEDULER_SUPPLEMENTAL_SYMBOLS_PER_RUN=120  # Off-hours rotating company refresh slice
SCHEDULER_WEEKEND_SYMBOLS_PER_RUN=300  # Broader weekend company refresh slice
SCHEDULER_COMPANY_NEWS_LIMIT=10  # Per-symbol company news fetch limit in supplemental sync
INTRADAY_LIMIT=500
ORDERFLOW_AT_CLOSE_ONLY=true
ORDERBOOK_AT_CLOSE_ONLY=true
STORE_INTRADAY_TRADES=false
INTRADAY_REQUIRE_MARKET_HOURS=true
INTRADAY_ALLOW_OUT_OF_HOURS_IN_PROD=false

# Scraper Settings
SCRAPER_ENABLED=true
SCRAPER_TIMEOUT=60
SCRAPER_MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO

# LLM Configuration (AI Copilot)
# OpenRouter (recommended - default)
OPENROUTER_API_KEY=your-openrouter-api-key-here
LLM_PROVIDER=openrouter
LLM_MODEL=openrouter/free
ENABLE_AI_SENTIMENT_ANALYSIS=0  # Keep news sentiment paused until runtime is stable

# Optional OpenRouter attribution headers
# OPENROUTER_SITE_URL=https://your-app.example.com
# OPENROUTER_APP_NAME=VNIBB

# Context7 MCP
CONTEXT7_API_KEY=your-context7-api-key-here
