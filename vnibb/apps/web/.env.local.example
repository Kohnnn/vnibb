# Web local development environment
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/ws/prices
NEXT_PUBLIC_ENABLE_REALTIME=true
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_your_public_project_key

# Auth provider
NEXT_PUBLIC_AUTH_PROVIDER=supabase

# Optional Appwrite auth flow for later evaluation; do not switch production this month
# NEXT_PUBLIC_AUTH_PROVIDER=appwrite
# NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
# NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-appwrite-project-id
