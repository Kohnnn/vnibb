# Web production environment
# These values are required in production. Do not leave them blank.
NEXT_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_WS_URL=wss://api.example.com/api/v1/ws/prices
NEXT_PUBLIC_ENABLE_REALTIME=true
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=phc_your_public_project_key

# Appwrite / auth
# Global and tenant dashboard layouts are fetched through backend APIs, so the frontend does not need collection ids.
NEXT_PUBLIC_AUTH_PROVIDER=supabase
# This month keep Supabase auth active. Only switch next month if you intentionally re-evaluate Appwrite auth.
# NEXT_PUBLIC_AUTH_PROVIDER=appwrite
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your-appwrite-project-id
