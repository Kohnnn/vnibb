# Copy this file to deployment/env.oracle before deploying to Oracle.

# Public hostnames
SITE_HOSTNAME=api.example.com
ACME_EMAIL=ops@example.com
API_UPSTREAM=api:8000

# Runtime
ENVIRONMENT=production
DEBUG=false
TZ=Asia/Ho_Chi_Minh
INTRADAY_MARKET_TZ=Asia/Ho_Chi_Minh
PORT=8000
API_HOST=0.0.0.0
API_PORT=8000
UVICORN_PROXY_HEADERS=1
FORWARDED_ALLOW_IPS=172.16.0.0/12

# Immutable release image. Keep repository and digest separate so Compose cannot accept a mutable tag.
VNIBB_API_IMAGE_REPOSITORY=registry.example.com/vnibb/api
VNIBB_API_IMAGE_DIGEST=sha256:replace-with-published-image-digest
# The image stores its release revision at build time; stale RELEASE_REVISION keys are ignored.

# Datastores
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/vnibb
DATABASE_URL_SYNC=postgresql://user:password@host:5432/vnibb
DATA_BACKEND=hybrid
CACHE_BACKEND=redis
REDIS_URL=redis://default:password@host:6379/0
RATE_LIMIT_MODE=shadow
MEMORY_CACHE_MAX_ENTRY_BYTES=1048576
ALLOW_ANONYMOUS_DASHBOARD_WRITES=true
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Shared Mongo market data for microstructure/technical widgets.
# Use shared raw/analytical market records only; do not store VNIBB-native app state here.
MONGODB_ENABLED=true
MONGODB_DATABASE=vnibb-market
MONGODB_URL=mongodb+srv://user:password@cluster.example.net/vnibb-market?retryWrites=true&w=majority
MONGODB_TIMEOUT_MS=10000
PRICE_BACKFILL_START_DATE=2000-01-01
PRICE_HISTORY_YEARS=30

# Appwrite runtime
# Keep configured only if you still need legacy reads or manual backfills.
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_API_KEY=your-appwrite-server-api-key
APPWRITE_DATABASE_ID=your-existing-vnibb-appwrite-database-id
APPWRITE_SYSTEM_TEMPLATES_COLLECTION_ID=system_dashboard_templates
APPWRITE_WRITE_ENABLED=false
# Future tenant collections (documented; not required for admin-first global publish yet)
# APPWRITE_TENANT_TEMPLATES_COLLECTION_ID=tenant_dashboard_templates
# APPWRITE_TENANT_MEMBERSHIPS_COLLECTION_ID=tenant_memberships
# APPWRITE_TENANT_AUDIT_COLLECTION_ID=tenant_audit_logs
APPWRITE_POPULATE_MAX_ROWS=1000
APPWRITE_POPULATE_FULL_MAX_ROWS=0
APPWRITE_POPULATE_BATCH_SIZE=300
APPWRITE_POPULATE_CONCURRENCY=4
APPWRITE_POPULATE_FORCE_HTTP=1
APPWRITE_POPULATE_RESUME=true

# VNIBB Read-only MCP companion service
VNIBB_MCP_HOST=0.0.0.0
VNIBB_MCP_PORT=8001
VNIBB_MCP_TRANSPORT=streamable-http
VNIBB_MCP_URL=http://mcp:8001/mcp
VNIBB_MCP_TIMEOUT_SECONDS=20
VNIBB_MCP_SHARED_BEARER_TOKEN=replace-with-long-random-value
MCP_UPSTREAM=mcp:8001
# Optional direct host binding for smoke checks or non-Caddy host access.
# Safe default keeps the raw MCP HTTP port on localhost only.
MCP_PUBLIC_BIND=127.0.0.1
MCP_PUBLIC_PORT=8001

# Frontend origins allowed to call this backend
CORS_ORIGINS=["https://vnibb-web.vercel.app","https://vnibb.vercel.app"]
CORS_ORIGIN_REGEX=^https://[a-z0-9-]+\\.vercel\\.app$

# Providers and observability
VNSTOCK_API_KEY=your-vnstock-api-key
# Set only when the pinned VNIBB API image was built with the same premium module set.
# VNSTOCK_PREMIUM_REQUIRED_MODULES=vnstock_data,vnstock_ta,vnstock_pipeline,vnstock_news,vnii
VNSTOCK_SOURCE=KBS  # VNIBB default; supported sources are KBS, VCI, DNSE
VNSTOCK_CALLS_PER_MINUTE=100
INTRADAY_SYMBOLS_PER_RUN=60
SCHEDULER_LIVE_SYMBOLS_PER_RUN=60
SCHEDULER_SUPPLEMENTAL_SYMBOLS_PER_RUN=120
SCHEDULER_WEEKEND_SYMBOLS_PER_RUN=300
SCHEDULER_COMPANY_NEWS_LIMIT=10
SCHEDULER_LOCK_ENABLED=true
SCHEDULER_LOCK_MODE=required
SCHEDULER_LOCK_KEY_PREFIX=vnibb:scheduler-lock
SCHEDULER_LOCK_TTL_MARGIN_SECONDS=60
ORDERFLOW_AT_CLOSE_ONLY=true
ORDERBOOK_AT_CLOSE_ONLY=true
STORE_INTRADAY_TRADES=false
INTRADAY_REQUIRE_MARKET_HOURS=true
INTRADAY_ALLOW_OUT_OF_HOURS_IN_PROD=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# OCI Compose resource and Docker JSON/local log limits. Tune from measured baselines.
API_CPUS=1.50
API_MEM_LIMIT=4g
API_PIDS_LIMIT=256
SCHEDULER_CPUS=1.00
SCHEDULER_MEM_LIMIT=2g
SCHEDULER_PIDS_LIMIT=256
MCP_CPUS=0.50
MCP_MEM_LIMIT=1g
MCP_PIDS_LIMIT=128
CADDY_CPUS=0.50
CADDY_MEM_LIMIT=512m
CADDY_PIDS_LIMIT=128
REDIS_CPUS=0.50
REDIS_MEM_LIMIT=512m
REDIS_PIDS_LIMIT=128
DOCKER_LOG_DRIVER=local
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=3
SENTRY_DSN=https://your-dsn@sentry.io/project-id
ADMIN_API_KEY=replace-with-long-random-value
# Admins can save this key locally in the UI and publish global Initial layouts without SSH access after deploy.

# Startup tuning
STARTUP_DB_CHECK_TIMEOUT_SECONDS=12
STARTUP_VNSTOCK_REG_TIMEOUT_SECONDS=10
STARTUP_WS_TIMEOUT_SECONDS=5
SKIP_WARMUP=false
API_SKIP_SCHEDULER_STARTUP=true
SKIP_WEBSOCKET_STARTUP=false

# Companion Vercel env values
# Use the public Caddy hostname that actually terminates TLS. Do not point Vercel
# at a raw HTTP-only API port as `https://...`; browsers will fail with
# `ERR_SSL_PROTOCOL_ERROR` before VNIBB code can read the response.
# NEXT_PUBLIC_API_URL=https://api.example.com
# NEXT_PUBLIC_WS_URL=wss://api.example.com/api/v1/ws/prices
