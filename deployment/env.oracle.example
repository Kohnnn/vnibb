# Copy this file to deployment/env.oracle before deploying to Oracle.

# Public hostnames
SITE_HOSTNAME=api.example.com
ACME_EMAIL=ops@example.com
API_UPSTREAM=api:8000

# Runtime
ENVIRONMENT=production
DEBUG=false
TZ=Asia/Ho_Chi_Minh
INTRADAY_MARKET_TZ=Asia/Ho_Chi_Minh
PORT=8000
API_HOST=0.0.0.0
API_PORT=8000
UVICORN_PROXY_HEADERS=1
FORWARDED_ALLOW_IPS=*
ALEMBIC_STRICT=1

# Datastores
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/vnibb
DATABASE_URL_SYNC=postgresql://user:password@host:5432/vnibb
DATA_BACKEND=appwrite
CACHE_BACKEND=redis
REDIS_URL=redis://default:password@host:6379/0

# Appwrite runtime
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_API_KEY=your-appwrite-server-api-key
APPWRITE_DATABASE_ID=your-appwrite-database-id
APPWRITE_POPULATE_MAX_ROWS=1000
APPWRITE_POPULATE_FULL_MAX_ROWS=0
APPWRITE_POPULATE_BATCH_SIZE=300
APPWRITE_POPULATE_CONCURRENCY=4
APPWRITE_POPULATE_FORCE_HTTP=1
APPWRITE_POPULATE_RESUME=true

# Frontend origins allowed to call this backend
CORS_ORIGINS=["https://vnibb-web.vercel.app","https://vnibb.vercel.app"]
CORS_ORIGIN_REGEX=^https://[a-z0-9-]+\\.vercel\\.app$

# Providers and observability
VNSTOCK_API_KEY=your-vnstock-api-key
VNSTOCK_RUNTIME_INSTALL=0
VNSTOCK_AUTO_BOOTSTRAP_ON_MISSING=1
VNSTOCK_AUTO_BOOTSTRAP_INTERVAL_SECONDS=43200
VNSTOCK_AUTO_BOOTSTRAP_MAX_FAILED_ATTEMPTS=5
VNSTOCK_AUTO_BOOTSTRAP_LOCK_STALE_SECONDS=1800
VNSTOCK_PREMIUM_REQUIRED_MODULES=vnstock_data,vnstock_ta,vnstock_pipeline,vnstock_news,vnii
VNSTOCK_SOURCE=KBS
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=https://your-dsn@sentry.io/project-id
ADMIN_API_KEY=replace-with-long-random-value

# Startup tuning
STARTUP_DB_CHECK_TIMEOUT_SECONDS=12
STARTUP_VNSTOCK_REG_TIMEOUT_SECONDS=10
STARTUP_WS_TIMEOUT_SECONDS=5
SKIP_WARMUP=false
SKIP_SCHEDULER_STARTUP=false
SKIP_WEBSOCKET_STARTUP=false

# Companion Vercel env values
# NEXT_PUBLIC_API_URL=https://api.example.com
# NEXT_PUBLIC_WS_URL=wss://api.example.com/api/v1/ws/prices
